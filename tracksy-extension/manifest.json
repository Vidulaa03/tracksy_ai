{
  "manifest_version": 3,
  "name": "Tracksy — Save Jobs",
  "version": "1.0.0",
  "description": "Save jobs from LinkedIn and Indeed directly into your Tracksy account.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Tracksy"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://www.indeed.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/tracksy_icon.png",
    "48":  "icons/tracksy_icon.png",
    "128": "icons/tracksy_icon.png"
  }
}
